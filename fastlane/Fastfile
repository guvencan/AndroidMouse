default_platform(:android)

platform :android do

  desc "Upload metadata & screenshots to Play Store (no APK)"
  lane :metadata do
    supply(
      json_key: ENV["SUPPLY_JSON_KEY"],
      track: "production",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_images: false,
      skip_upload_screenshots: false,
    )
  end

  desc "Build signed release AAB"
  lane :build do
    gradle(
      task: "bundle",
      build_type: "Release",
      print_command: false,
    )
  end

  desc "Build & upload AAB to internal testing track"
  lane :internal do
    build
    supply(
      json_key: ENV["SUPPLY_JSON_KEY"],
      track: "internal",
      aab: lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH],
    )
  end

  desc "Promote internal → alpha"
  lane :alpha do
    supply(
      json_key: ENV["SUPPLY_JSON_KEY"],
      track: "internal",
      track_promote_to: "alpha",
    )
  end

  desc "Promote alpha → production"
  lane :production do
    supply(
      json_key: ENV["SUPPLY_JSON_KEY"],
      track: "alpha",
      track_promote_to: "production",
    )
  end

  desc "Bump versionCode and versionName, then build internal"
  lane :release do |options|
    version = options[:version] || UI.input("Version name (e.g. 1.1):")
    android_set_version_name(version_name: version)
    android_set_version_code
    internal
  end

end
